#!/bin/sh

realpath() (
    OURPWD=$PWD
    cd "$(dirname "$1")"
    LINK=$(readlink "$(basename "$1")")
    while [ "$LINK" ]; do
        cd "$(dirname "$LINK")"
        LINK=$(readlink "$(basename "$1")")
    done
    REALPATH="$PWD/$(basename "$1")"
    cd "$OURPWD"
    echo "$REALPATH"
)

SCRIPT=$(realpath "$0")
# Find a python3 or python that is version 3.8, or 3.14
 for py in python{3.14,3.8,3}; do
    if $py -V 2>&1 | grep -qE '^Python 3\.(8|9|[1-9][0-9])\.'; then
        exec $py "${SCRIPT}.py" "$@"
    fi
done
echo "No appropriate python interpreter found (3.8+ required)." >&2
exit 1
