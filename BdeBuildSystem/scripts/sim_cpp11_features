#!/bin/sh

realpath() (
    OURPWD=$PWD
    cd "$(dirname "$1")"
    LINK=$(readlink "$(basename "$1")")
    while [ "$LINK" ]; do
        cd "$(dirname "$LINK")"
        LINK=$(readlink "$(basename "$1")")
    done
    REALPATH="$PWD/$(basename "$1")"
    cd "$OURPWD"
    echo "$REALPATH"
)

SCRIPT=$(realpath "$0")
# Find a python3 or python that is version 3.9+
for py in python3.14 python3.12 python3.9 python3 python; do
    if $py -V 2>&1 | grep -qE '^Python 3\.(9|[1-9][0-9])\.'; then
        exec $py "${SCRIPT}.py" "$@"
    fi
done
echo "No appropriate python interpreter found (3.9+ required)." >&2
exit 1
